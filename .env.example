APP_NAME=AgentTrader
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
LOG_LEVEL=INFO

MYSQL_DSN=mysql+asyncmy://root:root@localhost:3306/agent_trader
MYSQL_ECHO=false
MYSQL_POOL_SIZE=10
MYSQL_MAX_OVERFLOW=20

MONGO_DSN=mongodb://localhost:27017
MONGO_DATABASE=agent_trader
MONGO_APP_NAME=agent-trader
MONGO_USERNAME=root
MONGO_PASSWORD=root

INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-influxdb-token-here
INFLUX_ORG=your-org
INFLUX_BUCKET=finance
INFLUX_TIMEOUT_MS=10000

# TuShare 数据源配置
# 标准模式：仅配置 TUSHARE_TOKEN，内部使用 ts.set_token("你的TOKEN") + ts.pro_api()
TUSHARE_TOKEN=your-tushare-token-here
# 第三方 URL 模式：配置该项后将使用 ts.pro_api(token) 并注入 _DataApi__http_url
TUSHARE_API_URL=

# 代理运行时默认设置
AGENT_MAX_CONCURRENCY=4
AGENT_DEFAULT_TIMEOUT_SECONDS=120
AGENT_CHECKPOINT_ENABLED=true

# 大模型 / 代理 模型设置（新增）
# 当没有指定映射时使用的默认模型
AGENT_DEFAULT_MODEL=gpt-4.1-mini

# 代理名称到模型的映射。使用可解析为字典的 JSON 字符串。
# 示例：将 news_preprocess 代理映射到特定模型。
AGENT_MODEL_MAP={"news_preprocess": "gpt-4.1"}

# OpenAI 提供者设置
# 使用 OpenAI 模型必须设置 API Key
OPENAI_API_KEY=
# 可选：自定义 base URL（例如使用代理或企业端点）
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SECONDS=60
OPENAI_TEMPERATURE=0.1

# Kline sync worker settings
SYNC_ENABLED_MARKETS=sse,szse
SYNC_D1_WINDOW_DAYS=730
SYNC_M5_WINDOW_DAYS=60
SYNC_REALTIME_M5_INTERVAL_SECONDS=60
SYNC_D1_SYNC_HOUR=17
SYNC_BACKFILL_BATCH_SYMBOLS=20
SYNC_M5_BACKFILL_CHUNK_DAYS=20

