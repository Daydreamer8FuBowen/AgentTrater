APP_NAME=AgentTrader
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
LOG_LEVEL=DEBUG

MYSQL_DSN=mysql+asyncmy://root:root@localhost:3306/agent_trader_dev
MYSQL_ECHO=true
MYSQL_POOL_SIZE=5
MYSQL_MAX_OVERFLOW=10

MONGO_DSN=mongodb://localhost:27017
MONGO_DATABASE=agent_trader_dev
MONGO_APP_NAME=agent-trader
MONGO_USERNAME=root
MONGO_PASSWORD=root

INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-influxdb-token-here
INFLUX_ORG=your-org
INFLUX_BUCKET=finance_dev
INFLUX_TIMEOUT_MS=10000

# TuShare 数据源配置
TUSHARE_TOKEN=your-tushare-token-here
